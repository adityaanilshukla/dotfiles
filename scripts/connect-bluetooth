#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.bluetooth.env"
LIB_FILE="$SCRIPT_DIR/.bluetooth.lib"

for f in "$ENV_FILE" "$LIB_FILE"; do
  if [[ ! -f "$f" ]]; then
    command -v notify-send >/dev/null 2>&1 && notify-send "Bluetooth Connect" "Missing: $f"
    echo "Missing: $f" >&2
    exit 1
  fi
done

# shellcheck disable=SC1090
source "$LIB_FILE"
# shellcheck disable=SC1090
source "$ENV_FILE"

if ! command -v rofi >/dev/null 2>&1; then
  bt_notify "Bluetooth Connect" "rofi not installed."
  exit 1
fi

if [[ -z "${BT_DEVICES[*]:-}" ]]; then
  bt_notify "Bluetooth Connect" "BT_DEVICES not set in .bluetooth.env."
  exit 1
fi

status_tag() {
  local name="$1"
  local mac
  mac="$(find_macs_by_name "$name" | head -n1 || true)"
  if [[ -z "$mac" ]]; then
    echo "unpaired"
  elif is_connected "$mac"; then
    echo "connected"
  elif is_paired "$mac"; then
    echo "paired"
  else
    echo "unpaired"
  fi
}

ENTRIES=()
for spec in "${BT_DEVICES[@]}"; do
  IFS='|' read -r label name kind <<<"$spec"
  [[ -z "$label" || -z "$name" || -z "$kind" ]] && continue
  tag="$(status_tag "$name")"
  line="$(printf '%-14s %-22s [%s]' "$label" "$name" "$tag")"
  ENTRIES+=("$label|$name|$kind|$line")
done

if [[ ${#ENTRIES[@]} -eq 0 ]]; then
  bt_notify "Bluetooth Connect" "No devices configured."
  exit 0
fi

MENU_INPUT=""
for entry in "${ENTRIES[@]}"; do
  MENU_INPUT+="${entry##*|}"$'\n'
done
MENU_INPUT="${MENU_INPUT%$'\n'}"

CHOICE="$(printf '%s\n' "$MENU_INPUT" | rofi -dmenu -i -p "connect" -no-custom)" || exit 0
[[ -z "$CHOICE" ]] && exit 0

SELECTED=""
for entry in "${ENTRIES[@]}"; do
  if [[ "${entry##*|}" == "$CHOICE" ]]; then
    SELECTED="$entry"
    break
  fi
done
[[ -z "$SELECTED" ]] && { bt_notify "Bluetooth Connect" "No match."; exit 1; }

IFS='|' read -r LABEL NAME KIND _ <<<"$SELECTED"

pause_all_media

mac="$(find_macs_by_name "$NAME" | head -n1 || true)"

if [[ -n "$mac" ]] && is_connected "$mac"; then
  bt_notify "$LABEL" "Already connected ($mac)."
elif [[ -n "$mac" ]] && is_paired "$mac" && quick_reconnect "$mac"; then
  bt_notify "$LABEL" "Reconnected ($mac)."
else
  bt_notify "$LABEL" "Running full re-pair flow..."
  if mac="$(full_repair "$NAME")"; then
    bt_notify "$LABEL" "Paired and connected ($mac)."
  else
    bt_notify "$LABEL" "Connection failed. Is the device in pairing mode?"
    exit 1
  fi
fi

if [[ "$KIND" == "audio" ]]; then
  if sink="$(activate_audio_profile "$mac")"; then
    bt_notify "$LABEL" "Audio routed to $sink."
  else
    bt_notify "$LABEL" "Connected, but PipeWire a2dp activation failed."
    exit 1
  fi
fi

exit 0
