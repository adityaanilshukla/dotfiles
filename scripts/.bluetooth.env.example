# .bluetooth.env
# One device per entry: "Display Label|Device Name|kind"
#   Device Name must match the name BlueZ reports (`bluetoothctl devices`).
#   kind = audio (activates PipeWire a2dp-sink profile after connect)
#        | input (skip audio profile step)
BT_DEVICES=(
  "Headphones|Sony WH-1000XM3|audio"
  "Mouse|MX Master 3|input"
  "Keyboard|Keychron K8|input"
)

# Optional knobs
# BT_SCAN_TIMEOUT=10            # bluetoothctl timeout
# BT_ACTIVE_SCAN_SECS=6         # active scan window during full re-pair
# BT_STRICT_NAME=0              # 1 = exact name match, 0 = substring (default)
