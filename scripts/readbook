#!/usr/bin/env bash

# --- internal list mode -------------------------------------------------
# Used by the fzf picker below (initial load + Tab reload): print one row per
# book as "<display>\t<fullpath>", then exit before the slower zathura env
# setup. $2 is the display mode:
#   name  -> just the filename
#   path  -> the path relative to ~/Documents, so directories are searchable
# The full path is always the second (hidden) field, so selection is
# unambiguous even when two books share a filename.
if [[ "${1:-}" == "--list" ]]; then
  find "$HOME/Documents" \
    -type f \( -iname "*.pdf" -o -iname "*.epub" -o -iname "*.mobi" -o -iname "*.djvu" \) \
    2>/dev/null | while IFS= read -r p; do
      if [[ "${2:-name}" == path ]]; then disp="${p#*/Documents/}"; else disp="${p##*/}"; fi
      printf '%s\t%s\n' "$disp" "$p"
    done
  exit 0
fi

# Absolute path to this script, so the fzf Tab-reload can re-invoke it.
SELF="$0"; [[ "$SELF" != /* ]] && SELF="$PWD/$SELF"

# --- environment (important for GUI launches) ---
# GUI keybind invocations don't inherit a normal shell env, so we set up
# PATH (incl. ~/.local/bin for online-zathura), source the project-scoped
# Turso creds, and pin both binaries.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
[[ -f "$HOME/.secrets" ]] && source "$HOME/.secrets"

ZATHURA="/opt/homebrew/bin/zathura"
ONLINE_ZATHURA="$HOME/.local/bin/online-zathura"

PDF_POPPLER="$(dirname "$(find "$(brew --cellar zathura-pdf-poppler)" -name 'libpdf-poppler.dylib' | head -n1)")"
PDF_MUPDF="$(dirname "$(find "$(brew --cellar zathura-pdf-mupdf)" -name 'libpdf-mupdf.dylib' | head -n1)")"

export ZATHURA_PLUGINS_PATH="$PDF_POPPLER:$PDF_MUPDF"

# --- book picker ---
# The list shows each book's filename. Press Tab to switch the whole list to
# show paths relative to ~/Documents instead, so you can fuzzy-match on a
# directory too; Tab again switches back. A temp file holds the current mode so
# the Tab reload knows which way to flip. --with-nth=1/--nth=1 keep the hidden
# full-path field out of both the display and the search.
MODE_FILE=$(mktemp)
export MODE_FILE
printf 'name\n' > "$MODE_FILE"

SEL=$("$SELF" --list name | fzf \
  --delimiter='\t' --with-nth=1 --nth=1 \
  --bind 'tab:reload(m=$(cat "$MODE_FILE"); [ "$m" = name ] && m=path || m=name; printf "%s\n" "$m" > "$MODE_FILE"; '"$SELF"' --list "$m")')

rm -f "$MODE_FILE"

# Recover the full path (the field after the tab); empty if fzf was cancelled.
BOOK="${SEL#*$'\t'}"

# Nothing selected (fzf cancelled) — bail before launching anything.
[[ -z "$BOOK" ]] && exit 0

# List the AeroSpace window-ids of every open zathura window. zathura has no
# app bundle id on macOS, so we match by app-name.
zathura_ids() {
  aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null \
    | awk -F'|' '$2 == "zathura" { print $1 }'
}

# Highest existing zathura window-id (0 if none). AeroSpace window-ids are
# monotonically increasing, so the window we're about to open will have a
# larger id than any already open — that's how we single it out.
before_max=$(zathura_ids | sort -n | tail -n1)
before_max=${before_max:-0}

# --- launch ---
# Route through online-zathura: it pulls reading state from Turso, execs
# real zathura (via ZATHURA_BINARY), and pushes deltas back when you close
# the window. nohup+& detaches the whole wrapper so alacritty can close.
ZATHURA_BINARY="$ZATHURA" nohup "$ONLINE_ZATHURA" "$BOOK" >/dev/null 2>&1 &

# --- focus zathura under AeroSpace ---
# AeroSpace (not macOS/AppleScript) governs keyboard focus, so an AppleScript
# `activate` doesn't reliably hand keystrokes to the reader. Poll (up to ~5s)
# for the newly-opened zathura window and focus it by window-id, so keypresses
# land in zathura without a manual click. Doing this while alacritty is still
# open (but now unfocused) means alacritty closing afterwards won't steal focus.
for _ in $(seq 1 50); do
  sleep 0.1
  wid=$(zathura_ids | sort -n | tail -n1)
  if [[ -n "$wid" && "$wid" -gt "$before_max" ]]; then
    aerospace focus --window-id "$wid"
    break
  fi
done
