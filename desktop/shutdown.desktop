[Desktop Entry]
Name=Shutdown
Comment=Shutdown the system after confirmation
Exec=sh -c 'zenity --question --title="Confirm Shutdown" --text="Are you sure you want to shut down?" --ok-label="Yes" --cancel-label="No" --icon-name=system-shutdown && systemctl poweroff'
Icon=system-shutdown
Terminal=false
Type=Application
Categories=System;
